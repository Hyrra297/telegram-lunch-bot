# Lấy từ @BotFather trên Telegram
BOT_TOKEN=your_bot_token_here

# Chat ID của nhóm (số âm, ví dụ: -1001234567890)
# Lấy bằng cách thêm bot vào nhóm rồi gửi tin nhắn, check /getUpdates
CHAT_ID=-1001234567890

# Telegram user_id của admin (phân cách bằng dấu phẩy)
# Lấy bằng cách nhắn tin @userinfobot
ADMIN_IDS=123456789,987654321

# Giờ mở/đóng vote (múi giờ Việt Nam)
VOTE_OPEN_TIME=08:00
VOTE_CLOSE_TIME=10:30

# Giá mỗi suất cơm (VND)
PRICE_PER_MEAL=35000

# Múi giờ
TIMEZONE=Asia/Ho_Chi_Minh

# Đường dẫn file database (mặc định cùng thư mục)
DB_PATH=lunch_bot.db
